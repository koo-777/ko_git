{
    "manifest_version": 3,
    "name": "Simple Work Timer",
    "version": "1.0",
    "description": "Simple extension to track work time.",
    "permissions": [
        "storage"
    ],
    "action": {
        "default_popup": "popup.html",
        "default_title": "Simple Work Timer"
    },
    "icons": {
        "16": "icon16.png",
        "48": "icon48.png",
        "128": "icon128.png"
    }
}